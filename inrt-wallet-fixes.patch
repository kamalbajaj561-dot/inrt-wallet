+  details: Record<string, any>;
+  amount: number;
+}) {
+  const ref = await addDoc(collection(db, 'bookings'), {
+    uid, ...data,
+    status:    'confirmed',
+    createdAt: serverTimestamp(),
+  });
+  await updateBalance(uid, -data.amount);
